<Window x:Class="ComPortVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audib COMListener_v2.8" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" FontFamily="Consolas" Foreground="#E0E0E0"
        Icon="/Images/appioc.ico">
    <Window.Background>
        <ImageBrush ImageSource="/Images/Copilot_20260518_115006.png" Stretch="UniformToFill" Opacity="1.0"/>
    </Window.Background>

    <Window.Resources>
        <SolidColorBrush x:Key="CyanBrush" Color="#00E5FF"/>
        <SolidColorBrush x:Key="NeonRedBrush" Color="#FF0044"/>

        <DropShadowEffect x:Key="CyanGlow" BlurRadius="20" Color="#00E5FF" ShadowDepth="0" Opacity="0.8"/>
        <DropShadowEffect x:Key="RedGlow" BlurRadius="20" Color="#FF0044" ShadowDepth="0" Opacity="0.8"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#880A1526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" Padding="15,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#AA003366"/>
                                <Setter TargetName="border" Property="Effect" Value="{StaticResource CyanGlow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DD00E5FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectBtnStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="#00E5FF" ShadowDepth="0" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DisconnectBtnStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="#88FF0044"/>
            <Setter Property="Foreground" Value="#FF0044"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource RedGlow}"/>
                    <Setter Property="Background" Value="#88330011"/>
                    <Setter Property="BorderBrush" Value="#FFFF0044"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveBtnStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="#8800FF99"/>
            <Setter Property="Foreground" Value="#00FF99"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#88003311"/>
                    <Setter Property="BorderBrush" Value="#FF00FF99"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#DD050D1A"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#AA003366"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#AA0077FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#66050D1A"/>
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="3">
                                            <Path Name="Arrow" Fill="{StaticResource CyanBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#88001C1F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder" Background="#DD050D1A" BorderBrush="{StaticResource CyanBrush}" BorderThickness="1" CornerRadius="2">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="#00E5FF" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AA050D1A" BorderBrush="#8800E5FF" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#0077FF" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="COM Port:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbPorts" Grid.Column="1" Height="30" DropDownOpened="CmbPorts_DropDownOpened" Margin="0,0,20,0"/>

                <TextBlock Grid.Column="2" Text="Baud Rate:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbBaudRate" Grid.Column="3" Height="30" Margin="0,0,20,0">
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="14400"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200" IsSelected="True"/>
                    <ComboBoxItem Content="256000"/>
                </ComboBox>

                <Button x:Name="BtnConnect" Style="{StaticResource ConnectBtnStyle}" Grid.Column="5" Content="Connect" Click="BtnConnect_Click" Height="35" Margin="0,0,10,0"/>
                <Button x:Name="BtnDisconnect" Style="{StaticResource DisconnectBtnStyle}" Grid.Column="6" Content="Disconnect" Click="BtnDisconnect_Click" Height="35" IsEnabled="False"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" HorizontalAlignment="Center" Background="#880A1526" BorderBrush="#8800E5FF" BorderThickness="1,0,1,1" CornerRadius="0,0,12,12" Padding="30,8" Margin="0,-15,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#00E5FF" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Received KB: " Foreground="#BBAAAAAA"/>
                <TextBlock x:Name="TxtRxKB" Text="0.00" Foreground="{StaticResource CyanBrush}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="Sent KB: " Foreground="#BBAAAAAA"/>
                <TextBlock x:Name="TxtTxKB" Text="0.00" Foreground="{StaticResource CyanBrush}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="Packets: " Foreground="#BBAAAAAA"/>
                <TextBlock x:Name="TxtPackets" Text="0" Foreground="{StaticResource CyanBrush}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="Errors: " Foreground="#BBAAAAAA"/>
                <TextBlock x:Name="TxtErrors" Text="0" Foreground="{StaticResource CyanBrush}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="Uptime: " Foreground="#BBAAAAAA"/>
                <TextBlock x:Name="TxtUptime" Text="00:00:00" Foreground="{StaticResource CyanBrush}" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#D5000000" BorderBrush="#6600E5FF" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="#00E5FF" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#990A1526" BorderBrush="#4400E5FF" BorderThickness="0,0,0,1" Padding="15,8" CornerRadius="8,8,0,0">
                    <TextBlock Text="Live Data Stream" FontSize="16" FontWeight="Bold" Foreground="#EEFFFFFF"/>
                </Border>

                <TextBox x:Name="TxtConsole" Grid.Row="1" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" 
                         IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                         FontSize="14" Padding="15" Margin="0">
                    <TextBox.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Background" Value="#44050D1A"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#CC050D1A" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="5" Margin="0,0,15,0">
                <TextBox x:Name="TxtSend" Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" 
                         VerticalAlignment="Center" Padding="15,10" FontSize="15" 
                         KeyDown="TxtSend_KeyDown" Tag="Enter command..."/>
            </Border>

            <Button x:Name="BtnSend" Grid.Row="0" Grid.Column="1" Content="Send" Click="BtnSend_Click" Height="40" Margin="0,0,10,0"/>
            <Button x:Name="BtnSave" Style="{StaticResource SaveBtnStyle}" Grid.Row="0" Grid.Column="2" Content="Save Log" Click="BtnSave_Click" Height="40"/>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,5,0">
                <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="Red" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="10" Color="Red" ShadowDepth="0" Opacity="0.8"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock x:Name="TxtStatus" Text="Disconnected" Foreground="#EEFFFFFF" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
