<Window x:Class="ComPortVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audib COM Listener v2.8" Height="600" Width="900"
        Background="#050505" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold" Foreground="#A0A0A0">

    <Window.Resources>
        <!-- // COLOR PALETTE & EFFECTS // -->
        <Color x:Key="NeonBlueColor">#00F2FF</Color>
        <SolidColorBrush x:Key="NeonBlueBrush" Color="{StaticResource NeonBlueColor}"/>
        <SolidColorBrush x:Key="DeepBlueBrush" Color="#001C1F"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0D0D0D"/>
        <DropShadowEffect x:Key="NeonGlow" BlurRadius="15" Color="{StaticResource NeonBlueColor}" ShadowDepth="0" Opacity="0.6"/>

        <!-- // CONTROL STYLES // -->
        <Style x:Key="NeonPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NeonBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Effect" Value="{StaticResource NeonGlow}"/>
        </Style>

        <!-- Modern Neon Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource NeonBlueBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NeonBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="2" Padding="15,8">
                            <Grid>
                                <!-- FIXED: Changed BlurRadiusEffect to BlurEffect -->
                                <Border x:Name="innerGlow" BorderBrush="{StaticResource NeonBlueBrush}" 
                                        BorderThickness="0" CornerRadius="1" Opacity="0">
                                    <Border.Effect>
                                        <BlurEffect Radius="5"/>
                                    </Border.Effect>
                                </Border>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="content"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource NeonBlueBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter TargetName="border" Property="Effect" Value="{StaticResource NeonGlow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00A9B3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styling the stylized input text box -->
        <Style x:Key="NeonTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource DeepBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00464F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CaretBrush" Value="{StaticResource NeonBlueBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource NeonBlueBrush}"/>
                                <Setter TargetName="border" Property="Effect" Value="{StaticResource NeonGlow}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource DeepBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource NeonBlueBrush}"/>
            <Setter Property="BorderBrush" Value="#00464F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- // LEFT PANEL: CONNECTION SETTINGS // -->
        <!-- FIXED: Moved Padding to Border, removed from Grid -->
        <Border Grid.Column="0" Style="{StaticResource NeonPanel}" Margin="0,0,25,0" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <!-- FIXED: Removed Tracking attribute -->
                    <TextBlock Text="SYSTEM CONNECTION" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    <Border Height="2" Background="{StaticResource NeonBlueBrush}" HorizontalAlignment="Left" Width="50" Margin="0,5,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" Color="{StaticResource NeonBlueColor}" ShadowDepth="0" Opacity="0.8"/>
                        </Border.Effect>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="INTERFACE PORT" Foreground="#808080" Margin="0,0,0,8" FontWeight="Normal"/>
                    <ComboBox x:Name="CmbPorts" Margin="0,0,0,20" Height="35" DropDownOpened="CmbPorts_DropDownOpened"/>

                    <TextBlock Text="BAUD RATE (BPS)" Foreground="#808080" Margin="0,0,0,8" FontWeight="Normal"/>
                    <ComboBox x:Name="CmbBaudRate" Margin="0,0,0,30" Height="35">
                        <ComboBoxItem Content="4800"/>
                        <ComboBoxItem Content="9600" IsSelected="True"/>
                        <ComboBoxItem Content="14400"/>
                        <ComboBoxItem Content="19200"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="57600"/>
                        <ComboBoxItem Content="115200"/>
                        <ComboBoxItem Content="256000"/>
                    </ComboBox>

                    <Button x:Name="BtnConnect" Content="ESTABLISH LINK" Click="BtnConnect_Click" Height="45" Margin="0,0,0,15"/>
                    <Button x:Name="BtnDisconnect" Content="TERMINATE LINK" Click="BtnDisconnect_Click" Height="45" 
                            BorderBrush="#FF4545" Foreground="#FF4545" IsEnabled="False">
                        <Button.Style>
                            <!-- FIXED: Corrected syntax to x:Type -->
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF4545"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" Color="#FF4545" ShadowDepth="0" Opacity="0.6"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1" Padding="15" CornerRadius="2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Red" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="10" Color="Red" ShadowDepth="0" Opacity="0.7"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <!-- FIXED: Removed Tracking attribute -->
                        <TextBlock x:Name="TxtStatus" Text="OFFLINE" Foreground="Gray" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- // RIGHT PANEL: TERMINAL LOG & SEND // -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FIXED: Moved Padding to Border, removed from Grid -->
            <Border Grid.Row="0" Style="{StaticResource NeonPanel}" Margin="0,0,0,25" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FIXED: Removed Tracking attribute -->
                    <TextBlock Grid.Row="0" Text="LIVE DATA STREAM" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                    <TextBox x:Name="TxtConsole" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                             FontFamily="Consolas" FontSize="13" Foreground="#B0FFFF">
                        <TextBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="#0D0D0D"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSend" Grid.Column="0" Style="{StaticResource NeonTextBox}"
                         VerticalAlignment="Center" FontSize="14" FontFamily="Consolas" Height="45"
                         KeyDown="TxtSend_KeyDown" Tag="Enter Command..."/>

                <Button x:Name="BtnSend" Grid.Column="1" Content="TRANSMIT" Width="120" Height="45" Margin="15,0,0,0" Click="BtnSend_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
